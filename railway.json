{
    "$schema": "https://railway.app/railway.json",
    "services": {
        "ironclaw-custom-railway": {
            "build": {
                "builder": "DOCKERFILE",
                "dockerfilePath": "Dockerfile"
            },
            "deploy": {
                "numReplicas": 1,
                "sleep": false,
                "restartPolicyType": "ON_FAILURE",
                "healthcheckPath": "/",
                "healthcheckTimeout": 100
            },
            "variables": {
                "DATABASE_URL": "postgresql://${{ services.postgres.variables.POSTGRES_USER }}:${{ services.postgres.variables.POSTGRES_PASSWORD }}@${{ services.postgres.variables.RAILWAY_PRIVATE_DOMAIN }}:5432/${{ services.postgres.variables.POSTGRES_DB }}"
            },
            "volumes": [
                {
                    "mountPath": "/home/ironclaw",
                    "name": "ironclaw-data"
                }
            ]
        },
        "postgres": {
            "image": "pgvector/pgvector:pg16-trixie",
            "variables": {
                "POSTGRES_DB": "ironclaw",
                "POSTGRES_USER": "ironclaw",
                "POSTGRES_PASSWORD": "${{ secret(16) }}"
            },
            "volumes": [
                {
                    "mountPath": "/var/lib/postgresql/data",
                    "name": "postgres-data"
                }
            ]
        }
    }
}